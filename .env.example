# ── AI Provider API Keys ─────────────────────────────────────────────
# At least one of these must be set depending on your chosen provider.
# Copy this file to .env (gitignored) and fill in your keys.

# Google Gemini API key (for AI provider "google")
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter API key (for AI provider "openrouter")
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Database Path ────────────────────────────────────────────────────
# Override the default database file. If unset, the app loads
# databases/northwind.db on first launch.
DB_PATH=

# ── Schema-RAG ───────────────────────────────────────────────────────
# Controls Schema-RAG embedding for large schemas.
# "auto" = use main AI provider's embedding model (default)
# "off"  = skip RAG, always send full schema
SCHEMA_RAG=auto
